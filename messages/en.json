      "guide": {
        "step1Title": "Create Feishu App",
        "step1_1": "Open Feishu Open Platform: https://open.feishu.cn/app",
        "step1_2": "Log in with your Feishu account, click Create Custom App",
        "step1_3": "Fill in app name (e.g. \"Claude Assistant\") and description, choose an icon",
        "step1_4": "After creation, you'll enter the app details page",
        "step1_5": "Click Credentials & Basic Info in the left menu",
        "step1_6": "Copy the App ID (format: cli_xxxxxxxxxxxx) and App Secret into the fields above",
        "step2Title": "Configure Bot & Event Subscription",
        "step2_1": "In the app details page, click Add App Capabilities in the left menu",
        "step2_2": "Find the Bot capability and add it",
        "step2_3": "Then click Event Subscriptions in the left menu",
        "step2_4": "Set the Request URL to: https://your-domain/api/bot/feishu",
        "step2_5": "Click Add Event, search and add the im.message.receive_v1 (receive message) event",
        "step2_6": "If the page shows a Verification Token and Encrypt Key, copy them into the fields above",
        "step2_7": "Encrypt Key is optional, it works without encryption as well",
        "step3Title": "Publish & Test",
        "step3_1": "Click the Save to .env.local button above to save all configuration",
        "step3_2": "Restart the Dashboard server for changes to take effect",
        "step3_3": "Go back to Feishu Open Platform, click Version Management & Release in the left menu",
        "step3_4": "Create a new version, fill in version number and release notes",
        "step3_5": "Click Apply for Release - for internal apps, it will be available after admin approval",
        "step3_6": "Once published, search for your bot name in Feishu and send a message to test!",
        "permissionsTitle": "Required Permissions",
        "permissionsDesc": "Make sure the following permissions are enabled in Permission Management:",
        "perm1": "im:message - Read and send messages",
        "perm2": "im:message.receive_v1 - Receive message events",
        "perm3": "contact:user.base:readonly - Read basic user info (optional)",
        "faqTitle": "Troubleshooting",
        "faq1Q": "Event subscription verification failed?",
        "faq1A": "Confirm the Request URL is correct and publicly accessible; ensure the Dashboard server is running; check if the Verification Token is entered correctly.",
        "faq2Q": "Bot not replying to messages?",
        "faq2A": "Confirm the app is published and approved; verify Bot capability is added; check App ID and App Secret are correct; review Dashboard console logs for errors.",
        "faq3Q": "Insufficient permissions?",
        "faq3A": "Check Permission Management page for required permissions; some permissions need admin approval; after changing permissions, republish the app version."
      },
